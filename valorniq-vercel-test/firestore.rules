rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- HELPER FUNCTIONS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(data) { return isSignedIn() && data.ownerId == request.auth.uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- VALIDATION HELPERS ---

    function isValidLead(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.status in ["new", "contacted", "qualified", "lost"]
          && data.ownerId == request.auth.uid
          && (data.email == null || (data.email is string && data.email.size() <= 256))
          && (data.estimatedValue == null || data.estimatedValue is number);
    }

    function isValidCustomer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.email is string && data.email.size() <= 256
          && data.status in ["active", "inactive"]
          && data.ownerId == request.auth.uid;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.sku is string && data.sku.size() <= 100
          && data.price is number && data.price >= 0
          && data.stock is int && data.stock >= 0
          && data.ownerId == request.auth.uid;
    }

    function isValidSalesOrder(data) {
      return data.customerId is string && isValidId(data.customerId)
          && data.items is list && data.items.size() > 0 && data.items.size() <= 100
          && data.totalValue is number && data.totalValue >= 0
          && data.status in ["draft", "confirmed", "shipped", "cancelled"]
          && data.ownerId == request.auth.uid;
    }

    function isValidActivity(data) {
      return data.relatedId is string && isValidId(data.relatedId)
          && data.relatedType in ["lead", "customer"]
          && data.type in ["note", "call", "email", "meeting"]
          && data.content is string && data.content.size() <= 5000
          && data.ownerId == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    match /leads/{leadId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(leadId) && isOwner(resource.data);
      allow create: if isSignedIn() && isValidLead(incoming()) 
                     && incoming().keys().hasAll(['name', 'status', 'ownerId'])
                     && incoming().keys().size() <= 10;
      allow update: if isSignedIn() && isOwner(resource.data) && isValidLead(incoming())
                     && incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && isOwner(resource.data);
    }

    match /customers/{customerId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(customerId) && isOwner(resource.data);
      allow create: if isSignedIn() && isValidCustomer(incoming())
                     && incoming().keys().hasAll(['name', 'email', 'ownerId'])
                     && incoming().keys().size() <= 10;
      allow update: if isSignedIn() && isOwner(resource.data) && isValidCustomer(incoming())
                     && incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && isOwner(resource.data);
    }

    match /products/{productId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(productId) && isOwner(resource.data);
      allow create: if isSignedIn() && isValidProduct(incoming())
                     && incoming().keys().hasAll(['name', 'sku', 'price', 'stock', 'ownerId'])
                     && incoming().keys().size() <= 10;
      allow update: if isSignedIn() && isOwner(resource.data) && isValidProduct(incoming())
                     && incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && isOwner(resource.data);
    }

    match /salesOrders/{orderId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(orderId) && isOwner(resource.data);
      allow create: if isSignedIn() && isValidSalesOrder(incoming())
                     && incoming().keys().hasAll(['customerId', 'items', 'totalValue', 'status', 'ownerId'])
                     && incoming().keys().size() <= 10;
      allow update: if isSignedIn() && isOwner(resource.data) && isValidSalesOrder(incoming())
                     && (
                       (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                       (existing().status == 'draft' && incoming().ownerId == existing().ownerId)
                     );
      allow delete: if isSignedIn() && isOwner(resource.data) && existing().status == 'draft';
    }

    match /activities/{activityId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(activityId) && isOwner(resource.data);
      allow create: if isSignedIn() && isValidActivity(incoming());
      allow update: if isSignedIn() && isOwner(resource.data) && isValidActivity(incoming())
                     && incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && isOwner(resource.data);
    }
  }
}
