# Environment configuration for Valorniq backend
# Copy this to .env and update with your values

# Application
SECRET_KEY=your-super-secret-key-change-this-in-production
DATABASE_URL=sqlite:///./valorniq.db

# AI/ML
GEMINI_API_KEY=your-gemini-api-key-here
ARIS_MODEL=gemini-3-flash-preview

# OAuth Providers (update with real credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

APPLE_CLIENT_ID=your-apple-client-id

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
